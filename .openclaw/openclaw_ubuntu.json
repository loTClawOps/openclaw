    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "你的toke"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
